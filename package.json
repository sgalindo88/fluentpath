{
  "name": "fluentpath",
  "version": "0.21.0",
  "description": "FluentPath — Language learning platform for adult immigrants",
  "private": true,
  "scripts": {
    "lint": "eslint src/scripts/",
    "lint:fix": "eslint src/scripts/ --fix",
    "format": "prettier --write src/scripts/ src/styles/ *.html",
    "format:check": "prettier --check src/scripts/ src/styles/ *.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "npx serve .",
    "clasp:push": "clasp push",
    "clasp:deploy": "clasp push && clasp deploy -d \"$(git log -1 --format=%s)\"",
    "clasp:status": "clasp status"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgalindo88/english-course.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sgalindo88/english-course/issues"
  },
  "homepage": "https://github.com/sgalindo88/english-course#readme",
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.2",
    "vitest": "^2.1.9"
  }
}
